msgstr "所有 beam 皆連續失敗 — 停止。"

#: src/crucible/orchestrator.py:549
msgid "No beams initialized — falling back to serial loop."
msgstr "無 beam 初始化 — 退回序列迴圈。"

#: src/crucible/preflight.py:21
msgid ""
"claude CLI not found on PATH.\n"
"Install: npm install -g @anthropic-ai/claude-code\n"
"Then authenticate: claude login"
msgstr ""
"在 PATH 中找不到 claude CLI。\n"
"安裝：npm install -g @anthropic-ai/claude-code\n"
"然後登入：claude login"

#: src/crucible/preflight.py:34
#, python-brace-format
msgid ""
"claude CLI found but not working.\n"
"Error: {error}\n"
"Try: claude login"
msgstr ""
"找到 claude CLI 但無法運作。\n"
"錯誤：{error}\n"
"請嘗試：claude login"

#: src/crucible/preflight.py:47
msgid "Warning: claude auth status timed out, skipping auth check"
msgstr "警告：claude 認證狀態檢查逾時，跳過認證檢查"

#: src/crucible/preflight.py:56
msgid ""
"claude CLI is not logged in.\n"
"Run: claude login"
msgstr ""
"claude CLI 尚未登入。\n"
"請執行：claude login"

#: src/crucible/preflight.py:64
msgid ""
"Warning: claude CLI too old to check auth status; consider updating. "
"Proceeding anyway."
msgstr "警告：claude CLI 版本過舊，無法檢查認證狀態；建議更新。仍繼續執行。"

#: src/crucible/preflight.py:70
#, python-brace-format
msgid ""
"Cannot determine claude auth status.\n"
"Output: {output}\n"
"Try: claude login"
msgstr ""
"無法判斷 claude 認證狀態。\n"
"輸出：{output}\n"
"請嘗試：claude login"
